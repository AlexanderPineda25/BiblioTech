# =============================================================================
# BiblioTech - Archivo de configuracion de entorno (.env.example)
# =============================================================================
# Copiar este archivo como `.env` y reemplazar los valores de marcador de posicion
# (`replace_with_*`) con credenciales reales.
#
# Este archivo unifica las variables necesarias para:
#   - Docker Compose (infraestructura local)
#   - Frontend React (Vite)
#   - Identity Service (.NET)
#   - Catalog Service (Node.js)
#   - Chatbot Service (Node.js)
#
# =============================================================================


# =============================================================================
# SECCION 1: BASE DE DATOS (PostgreSQL)
# Usada por Docker Compose y los tres servicios backend (.NET, catalog, chatbot).
# =============================================================================

# Nombre de la base de datos principal (catalogo + usuarios).
POSTGRES_DB=catalog_db

# Usuario administrador de PostgreSQL.
POSTGRES_USER=postgres

# Contrasena del usuario administrador (cambiar en produccion).
POSTGRES_PASSWORD=postgres123


# =============================================================================
# SECCION 2: PUERTOS DE SERVICIOS (Docker Compose)
# Puertos expuestos en localhost para cada contenedor/servicio.
# =============================================================================

# Puerto del frontend React servido por Nginx.
FRONTEND_PORT=4173

# Puerto del servicio de identidad (.NET Web API).
IDENTITY_PORT=5132

# Puerto del servicio de catalogo (Node.js / Express).
CATALOG_PORT=3002

# Puerto del servicio de chatbot (Node.js / Express).
CHATBOT_PORT=3003

# Puerto de PostgreSQL expuesto en el host.
POSTGRES_PORT=5432

# Puerto de Redis expuesto en el host.
REDIS_PORT=6379


# =============================================================================
# SECCION 3: URLs DE SERVICIOS BACKEND (Frontend Vite)
# El frontend compila estas URLs en tiempo de build.
# Deben coincidir con los puertos definidos arriba.
# =============================================================================

# URL del servicio de autenticacion (.NET Identity).
VITE_AUTH_SERVICE_URL=http://localhost:5132

# URL del servicio de catalogo (libros, recomendaciones).
VITE_CATALOG_SERVICE_URL=http://localhost:3002

# URL del servicio de chatbot (mensajes IA).
VITE_CHATBOT_SERVICE_URL=http://localhost:3003


# =============================================================================
# SECCION 4: CORS (Cross-Origin Resource Sharing)
# Origenes permitidos para las cookies httpOnly y las peticiones entre
# frontend y backend. Separados por comas.
# =============================================================================

# Origenes permitidos para CORS (incluir los puertos del frontend).
CORS_ORIGINS=http://localhost:4173,http://localhost:5173


# =============================================================================
# SECCION 5: PROVEEDOR DE IA PARA RECOMENDACIONES (Catalog Service)
# Motor de clasificacion/recomendacion de libros (Hugging Face).
# =============================================================================

# Proveedor de IA para recomendaciones: 'huggingface'.
AI_PROVIDER=huggingface

# Token de API de Hugging Face (obtener en https://huggingface.co/settings/tokens).
HF_API_TOKEN=replace_with_your_huggingface_token

# Modelo de clasificacion de texto para recomendaciones.
HF_MODEL=facebook/bart-large-mnli


# =============================================================================
# SECCION 6: PROVEEDORES DE IA PARA CHATBOT (Chatbot Service)
# Cadena de fallback: Gemini -> Groq -> OpenRouter.
# =============================================================================

# Proveedor principal de chat: 'gemini'.
CHAT_PROVIDER=gemini

# Alias adicional usado por el chatbot-service.
CHATBOT_PROVIDER=gemini

# Clave API de Google Gemini (obtener en https://aistudio.google.com/app/apikey).
GEMINI_API_KEY=replace_with_your_gemini_key

# Modelo de Gemini a utilizar.
GEMINI_MODEL=gemini-2.5-flash

# Clave API de Groq (fallback 1) (obtener en https://console.groq.com/keys).
GROQ_API_KEY=replace_with_your_groq_key

# Modelo de Groq a utilizar.
GROQ_MODEL=llama-3.1-8b-instant

# Clave API de OpenRouter (fallback 2) (obtener en https://openrouter.ai/keys).
OPENROUTER_API_KEY=replace_with_your_openrouter_key

# Modelo de OpenRouter a utilizar.
OPENROUTER_MODEL=mistralai/mistral-7b-instruct:free

# URL referer requerida por OpenRouter.
OPENROUTER_REFERER=http://localhost:4173

# Titulo de la aplicacion para OpenRouter.
OPENROUTER_TITLE=Biblioteca U


# =============================================================================
# SECCION 7: REDIS (Chatbot Events / Streams)
# =============================================================================

# URL de conexion a Redis (local o Azure Managed Redis).
REDIS_URL=redis://localhost:6379

# Nombre del stream de Redis para eventos del chatbot.
CHATBOT_STREAM_NAME=chatbot_events

# Nombre del grupo de consumidores del stream.
CHATBOT_STREAM_GROUP=chatbot_logger


# =============================================================================
# SECCION 8: AZURE SERVICE BUS (Catalog Events / Mensajeria)
# Requerido para enviar eventos del catalogo a la cola de mensajes.
# =============================================================================

# Cadena de conexion de Azure Service Bus (obtener en Azure Portal).
# AZURE_SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://...;SharedAccessKeyName=...;SharedAccessKey=...

# Nombre de la cola de Service Bus para eventos del catalogo.
# AZURE_SERVICE_BUS_QUEUE=library-logging-queue


# =============================================================================
# SECCION 9: JWT (JSON Web Token — Identity Service)
# Clave secreta para firmar tokens JWT. Minimo 32 caracteres (256 bits) para HMAC-SHA256.
# =============================================================================

# Clave secreta JWT (requerida). Usar un valor aleatorio seguro de al menos 32 caracteres.
# Ej: openssl rand -base64 48
JWT_SECRET=replace_with_your_jwt_secret_min_32_chars

# NOTA: .NET usa el formato Jwt__Key para leer esta variable de entorno.
# Si usas Docker Compose, la variable se mapea automaticamente.
# Si ejecutas el .NET Identity API directamente:
#   $env:Jwt__Key="tu-clave-secreta-aqui" (PowerShell)
#   export Jwt__Key="tu-clave-secreta-aqui" (Linux/Mac)
#
# Para entornos productivos, usa Azure Key Vault:
#   1. Crea un Key Vault en Azure Portal
#   2. Agrega un secret con nombre "Jwt--Key" (el guion doble es intencional para .NET)
#   3. Configura AZURE_KEY_VAULT_URL abajo
#   4. Programa.cs lo leerá automáticamente (DefaultAzureCredential = Managed Identity en AKS)
# AZURE_KEY_VAULT_URL=https://tu-keyvault.vault.azure.net/


# =============================================================================
# SECCION 11: DUCKDNS (DNS dinamico para despliegue en AKS)
# =============================================================================

# Token de DuckDNS para actualizaciones automaticas de DNS.
# Alternativa: crear el archivo `duckdns-token.txt` en la raiz del proyecto.
# DUCKDNS_TOKEN=your-duckdns-token


# =============================================================================
# SECCION 12: VARIABLES INTERNAS DE SERVICIOS (opcional)
# Normalmente Docker Compose inyecta estas automaticamente.
# Solo modificar si ejecutas servicios fuera de Docker.
# =============================================================================

# Puerto del servicio (inyectado por Docker Compose).
# PORT=3002

# Host de la base de datos (inyectado por Docker Compose).
# DB_HOST=postgres

# Puerto de la base de datos.
# DB_PORT=5432

# Nombre de la base de datos.
# DB_NAME=catalog_db

# Usuario de la base de datos.
# DB_USER=postgres

# Contrasena de la base de datos.
# DB_PASSWORD=postgres123

# URL del servicio de autenticacion (para validar tokens en catalog/chatbot).
# AUTH_SERVICE_URL=http://identity-service:5132

# Modo de entorno Node.js: 'development' | 'production'.
# NODE_ENV=development

# Habilitar SSL para PostgreSQL (requerido para Azure Database).
# DB_SSL=false

# Nombre del consumidor del stream de Redis (auto-generado si no se define).
# CHATBOT_STREAM_CONSUMER=chatbot-service-01

# =============================================================================
# INSTRUCCIONES DE USO
# =============================================================================
# 1. Copiar este archivo:  cp .env.example .env
# 2. Reemplazar todas las lineas que digan 'replace_with_your_*' con valores reales.
# 3. Para despliegue local con Docker:  docker compose up -d --build
# 4. Para desarrollo frontend:
#       cd Biblioteca-Frontend && npm install && npm run dev
# 5. Para desarrollo backend (.NET Identity):
#       cd biblioteca-microservicios/mini-identity-api-dotnet-main/...
#       dotnet run --project src/MiniIdentityApi.Api
# 6. Para desarrollo backend (Node.js catalog/chatbot):
#       cd biblioteca-microservicios/catalog-service && npm install && npm run dev
#       cd biblioteca-microservicios/chatbot-service && npm install && npm run dev
# =============================================================================
